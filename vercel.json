{
  "version": 2,
  "builds": [
    {
      "src": "api/blogs.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "js/**",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/blogs.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}